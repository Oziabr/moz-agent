{
  "manifest_version": 3,
  "name": "moz-agent",
  "version": "0.1.0",
  "description": "Agentic browser session connector - stub",
  "browser_specific_settings": {
    "gecko": {
      "id": "moz-agent@oziabr.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*"],
      "js": ["test-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://app.moz-agent.example/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "moz-agent"
  },
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://app.moz-agent.example/*"],
  "optional_host_permissions": ["*://*/*"]
}
